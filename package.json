{
  "name": "weight-track",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:frontend\"",
    "dev:server": "WITHOUT_PASSWORD=true bun --watch server/main.ts",
    "dev:frontend": "vite --host",
    "build": "vite build",
    "start": "bun server/main.ts",
    "test": "bun test",
    "typecheck": "tsc -b --noEmit",
    "generate-first-passwords": "bun run server/generate-first-passwords.ts",
    "users-without-passwords": "bun run server/users-without-passwords.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "@types/bun": "latest",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "concurrently": "^9.2.0",
    "knip": "^6.16.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/x-charts": "^8.7.0",
    "@vitejs/plugin-react": "^4.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.2"
  }
}